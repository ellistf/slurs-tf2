{
  "name": "slurs-tf2",
  "version": "0.1.0",
  "main": "electron/main.cjs",
  "private": true,
  "scripts": {
    "renderer:dev": "vite",
    "renderer:preview": "vite preview",
    "dev": "node scripts/electron-launch.mjs dev",
    "build": "vite build",
    "start": "node scripts/electron-launch.mjs start",
    "electron:dev": "node scripts/electron-launch.mjs dev",
    "electron:start": "node scripts/electron-launch.mjs start",
    "electron:portable": "npm run build && electron-builder --win portable --publish never",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "lucide-react": "^1.7.0",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-router-dom": "^7.13.2"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^22.15.3",
    "@types/react": "^18.3.23",
    "@types/react-dom": "^18.3.7",
    "@vitejs/plugin-react": "^5.0.4",
    "autoprefixer": "^10.4.21",
    "electron": "^41.1.0",
    "electron-builder": "^26.0.12",
    "jsdom": "^26.1.0",
    "postcss": "^8.5.3",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.8.3",
    "vite": "^7.3.1",
    "vitest": "^3.1.2"
  },
  "build": {
    "appId": "com.ellistf.slurstf2",
    "productName": "Slurs.tf2",
    "artifactName": "Slurs.tf2-${version}-portable.${ext}",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "public/icon.png",
      "public/icon.ico",
      "package.json"
    ],
    "win": {
      "target": [
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "public/icon.ico"
    },
    "portable": {
      "artifactName": "Slurs.tf2-${version}-portable.${ext}"
    }
  }
}
